#!/bin/bash
set -e

case "$1" in
    configure)
        # Create brainrotfilter system user if it does not exist
        if ! getent passwd brainrotfilter >/dev/null 2>&1; then
            adduser --system --group --home /var/lib/brainrotfilter \
                --no-create-home --shell /usr/sbin/nologin \
                brainrotfilter || true
        fi

        # Set up Python virtual environment
        if [ ! -d /opt/brainrotfilter/venv ]; then
            echo "Creating Python virtual environment..."
            python3 -m venv /opt/brainrotfilter/venv
        fi

        # Install Python dependencies
        if [ -f /opt/brainrotfilter/requirements.txt ]; then
            echo "Installing Python dependencies..."
            /opt/brainrotfilter/venv/bin/pip install --quiet --upgrade pip
            /opt/brainrotfilter/venv/bin/pip install --quiet \
                -r /opt/brainrotfilter/requirements.txt
        fi

        # Set directory ownership
        chown -R brainrotfilter:brainrotfilter /var/lib/brainrotfilter
        chown -R brainrotfilter:brainrotfilter /var/log/brainrotfilter
        chown -R brainrotfilter:brainrotfilter /etc/brainrotfilter
        chown -R brainrotfilter:brainrotfilter /opt/brainrotfilter

        # Set permissions
        chmod 750 /var/lib/brainrotfilter
        chmod 750 /var/log/brainrotfilter
        chmod 750 /etc/brainrotfilter
        chmod 755 /usr/lib/brainrotfilter/scripts/*.sh

        # Install polkit rule so the brainrotfilter service user can trigger
        # the privileged brainrotfilter-squid-apply.service without sudo.
        # (NoNewPrivileges=true in the main service unit blocks sudo entirely.)
        # polkit is a package dependency; create rules.d if it doesn't exist yet
        # (can happen when polkit is being configured in the same apt run).
        mkdir -p /etc/polkit-1/rules.d
        install -m 0644 /usr/share/brainrotfilter/polkit/50-brainrotfilter.rules \
            /etc/polkit-1/rules.d/50-brainrotfilter.rules

        # Make the privileged helper script executable
        chmod 0755 /usr/lib/brainrotfilter/scripts/apply_squid_config.sh 2>/dev/null || true

        # Add brainrotfilter to the proxy group so it can read Squid files
        usermod -aG proxy brainrotfilter 2>/dev/null || true

        # Enable and start the service
        systemctl daemon-reload
        systemctl enable brainrotfilter-squid-apply.service || true
        systemctl enable brainrotfilter.service || true
        systemctl start brainrotfilter.service || true

        echo ""
        echo "======================================"
        echo "  BrainrotFilter installed!"
        echo "======================================"
        echo ""
        echo "  Admin panel: http://$(hostname -I | awk '{print $1}'):8199"
        echo "  Setup wizard will run on first visit."
        echo ""
        echo "  Service: systemctl status brainrotfilter"
        echo "  Logs:    journalctl -u brainrotfilter -f"
        echo ""
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument: $1" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
