[Unit]
Description=BrainrotFilter Console Menu
After=multi-user.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/lib/brainrotfilter/tui/console_tui.py
StandardInput=tty
StandardOutput=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
