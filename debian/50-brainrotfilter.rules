// /etc/polkit-1/rules.d/50-brainrotfilter.rules
// Allows the brainrotfilter system user to start the privileged
// brainrotfilter-squid-apply.service without a password prompt.
// This is required because the main service runs with NoNewPrivileges=true
// which prevents sudo, so systemctl is used instead.

polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        action.lookup("unit") == "brainrotfilter-squid-apply.service" &&
        (action.lookup("verb") == "start") &&
        subject.user == "brainrotfilter") {
        return polkit.Result.YES;
    }
});
