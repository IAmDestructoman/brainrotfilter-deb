#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	@echo "No build step needed (pure Python)"

override_dh_auto_install:
	# Create directories
	install -d $(CURDIR)/debian/brainrotfilter/opt/brainrotfilter
	install -d $(CURDIR)/debian/brainrotfilter/opt/brainrotfilter/src/brainrotfilter
	install -d $(CURDIR)/debian/brainrotfilter/etc/brainrotfilter
	install -d $(CURDIR)/debian/brainrotfilter/etc/brainrotfilter/ssl
	install -d $(CURDIR)/debian/brainrotfilter/var/lib/brainrotfilter
	install -d $(CURDIR)/debian/brainrotfilter/var/log/brainrotfilter
	install -d $(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/www/templates
	install -d $(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/www/static/css
	install -d $(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/www/static/js
	install -d $(CURDIR)/debian/brainrotfilter/usr/lib/brainrotfilter/scripts
	install -d $(CURDIR)/debian/brainrotfilter/etc/squid/conf.d

	# Install Python source
	install -m 644 $(CURDIR)/src/brainrotfilter/*.py \
		$(CURDIR)/debian/brainrotfilter/opt/brainrotfilter/src/brainrotfilter/

	# Install requirements
	install -m 644 $(CURDIR)/requirements.txt \
		$(CURDIR)/debian/brainrotfilter/opt/brainrotfilter/

	# Install templates
	install -m 644 $(CURDIR)/templates/*.html \
		$(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/www/templates/

	# Install static files
	install -m 644 $(CURDIR)/static/css/*.css \
		$(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/www/static/css/
	install -m 644 $(CURDIR)/static/js/*.js \
		$(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/www/static/js/

	# Install data files
	install -m 644 $(CURDIR)/data/keywords.json \
		$(CURDIR)/debian/brainrotfilter/etc/brainrotfilter/keywords.json
	install -m 644 $(CURDIR)/data/community-keywords.json \
		$(CURDIR)/debian/brainrotfilter/etc/brainrotfilter/community-keywords.json

	# Install shell scripts
	install -m 755 $(CURDIR)/scripts/squid_redirector.sh \
		$(CURDIR)/debian/brainrotfilter/usr/lib/brainrotfilter/scripts/
	install -m 755 $(CURDIR)/scripts/squid_acl_helper.sh \
		$(CURDIR)/debian/brainrotfilter/usr/lib/brainrotfilter/scripts/
	install -m 755 $(CURDIR)/scripts/state_killer.sh \
		$(CURDIR)/debian/brainrotfilter/usr/lib/brainrotfilter/scripts/
	install -m 755 $(CURDIR)/scripts/apply_squid_config.sh \
		$(CURDIR)/debian/brainrotfilter/usr/lib/brainrotfilter/scripts/

	# Install polkit rules for privileged squid config helper.
	# .rules  = JS format for polkitd >= 0.106 (Ubuntu 23.04+, Debian bookworm+)
	# .pkla   = local authority format for polkitd 0.105 (Ubuntu 22.04, Debian bullseye)
	# postinst installs the appropriate file based on polkit version.
	install -d $(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/polkit
	install -m 644 $(CURDIR)/debian/50-brainrotfilter.rules \
		$(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/polkit/
	install -m 644 $(CURDIR)/debian/50-brainrotfilter.pkla \
		$(CURDIR)/debian/brainrotfilter/usr/share/brainrotfilter/polkit/

	# Install Squid config snippet
	install -m 644 $(CURDIR)/debian/brainrotfilter-squid.conf \
		$(CURDIR)/debian/brainrotfilter/etc/squid/conf.d/brainrotfilter.conf

	# systemd service files are handled automatically by dh_installsystemd
	# (reads debian/brainrotfilter.service and debian/brainrotfilter-squid-apply.service)
	# Do NOT manually install them here — on Ubuntu 22.04+ /lib -> /usr/lib (usrmerge)
	# causes dpkg to see duplicate paths and fail with ENOENT on the .dpkg-new file.

override_dh_installsystemd:
	# Install the privileged helper service manually to lib/systemd/system/
	# (dh_installsystemd only auto-detects debian/brainrotfilter.service by
	# default; the squid-apply service has a different name prefix).
	# Using lib/ (not usr/lib/) works correctly on both usrmerge and non-merged
	# systems.  Do NOT also install to usr/lib/ — on Ubuntu 22.04+
	# /lib -> usr/lib so dpkg would see duplicate paths.
	install -d $(CURDIR)/debian/brainrotfilter/lib/systemd/system/
	install -m 644 $(CURDIR)/debian/brainrotfilter-squid-apply.service \
		$(CURDIR)/debian/brainrotfilter/lib/systemd/system/brainrotfilter-squid-apply.service
	dh_installsystemd

override_dh_auto_test:
	@echo "Skipping tests during package build"

override_dh_auto_clean:
	@echo "Nothing to clean"
